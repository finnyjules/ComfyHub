---
import { ClientRouter } from 'astro:transitions';
import AppNavbar from '../components/global/AppNavbar.vue';
import SmoothScroll from '../components/global/SmoothScroll.vue';
import SearchModal from '../components/global/SearchModal.vue';
import AppToast from '../components/global/AppToast.vue';
import AppFooter from '../components/global/AppFooter.astro';
import '../styles/global.scss';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'ComfyCloud — Community Workflow Library',
  description = 'Discover, run, and share 1,000+ community-built ComfyUI workflows in the cloud. No setup required.',
  ogImage = '/og-image.png',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <AppNavbar client:load transition:persist />
    <a href="#main-content" class="sr-only">Skip to main content</a>
    <main id="main-content">
      <slot />
    </main>
    <AppFooter />
    <SmoothScroll client:load />
    <SearchModal client:load />
    <AppToast client:idle />
  </body>
</html>

<style lang="scss" is:global>
  body {
    padding-top: calc($nav-height + $space-6);
  }

  main {
    min-height: calc(100vh - $nav-height);
  }
</style>
